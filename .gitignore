# ╔══════════════════════════════════════╗
# ║         EmbedMindAI .gitignore       ║
# ╚══════════════════════════════════════╝

# ── Environment & Secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
!**/.env.example

# ── OS & Editor ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# ── Git ───────────────────────────────────────────────────────────────────────
*.orig
*.rej

# ─────────────────────────────────────────────────────────────────────────────
# BACKEND (Python / FastAPI)
# ─────────────────────────────────────────────────────────────────────────────

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyw
.Python

# Virtual environments
venv/
env/
.venv/
.env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
site-packages/

# Test & coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# Type checking
.mypy_cache/
.pytype/

# Jupyter
.ipynb_checkpoints/

# Uploaded files (persisted via Docker volume — not in git)
backend/uploads/
uploads/

# ChromaDB vector store (persisted via Docker volume — not in git)
backend/chromadb_storage/
chromadb_storage/

# HuggingFace model cache (large, downloaded at build time)
backend/.cache/
.cache/

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND (Next.js / Node)
# ─────────────────────────────────────────────────────────────────────────────

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build output
frontend/.next/
frontend/out/
.next/
out/

# Production build
build/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vercel
.vercel

# ─────────────────────────────────────────────────────────────────────────────
# DOCKER
# ─────────────────────────────────────────────────────────────────────────────

# Docker doesn't need to be in git but the compose file does
# (nothing to ignore here — docker-compose.yml is committed)

# ─────────────────────────────────────────────────────────────────────────────
# MISC
# ─────────────────────────────────────────────────────────────────────────────

# Certificates & keys
*.pem
*.key
*.crt
*.p12

# Logs
*.log
logs/

# Coverage reports
coverage/
